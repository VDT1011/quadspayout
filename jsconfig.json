{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "lib": ["ES2020", "DOM"]
  },
  "include": ["js/**/*.js"],
  "exclude": ["node_modules"]
}
